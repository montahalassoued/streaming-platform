{
  "name": "streaming-platform",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "ts-node src/main.ts",
    "start:dev": "ts-node src/main.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "migration:create": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:create -d src/data-source.ts",
    "migration:generate": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
    "migration:run": "node -r ts-node/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.5",
    "@nestjs/core": "^10.4.5",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.5",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^10.4.22",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.3",
    "class-validator": "^0.14.4",
    "dotenv": "^17.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^4.6.3",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.5",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "@types/passport-local": "^1.0.38",
    "eslint": "^9.25.1",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
